default_platform(:ios)

platform :ios do
  before_all do
    if ENV["ASC_KEY_ID"] && ENV["ASC_ISSUER_ID"] && ENV["ASC_KEY_PATH"]
      @api_key = app_store_connect_api_key(
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key_filepath: ENV["ASC_KEY_PATH"],
      )
    end
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    build_path = File.expand_path("../Build/iOS")
    archive_path = File.expand_path("../Build/Murge.xcarchive")

    build_app(
      project: "#{build_path}/Unity-iPhone.xcodeproj",
      scheme: "Unity-iPhone",
      archive_path: archive_path,
      export_method: "app-store",
      configuration: "Release",
      export_options: {
        signingStyle: "automatic",
      },
      clean: false,
      skip_profile_detection: true,
    )

    upload_to_testflight(
      api_key: @api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
    )
  end

  desc "Build only (no upload)"
  lane :build_only do
    build_path = File.expand_path("../Build/iOS")
    archive_path = File.expand_path("../Build/Murge.xcarchive")

    build_app(
      project: "#{build_path}/Unity-iPhone.xcodeproj",
      scheme: "Unity-iPhone",
      archive_path: archive_path,
      export_method: "app-store",
      configuration: "Release",
      export_options: {
        signingStyle: "automatic",
      },
      clean: false,
      skip_profile_detection: true,
    )
  end

  desc "Upload existing IPA to TestFlight"
  lane :upload do
    ipa_path = Dir.glob(File.expand_path("../Build/IPA-prod/*.ipa")).first ||
               Dir.glob(File.expand_path("../Build/Murge.ipa")).first ||
               Dir.glob(File.expand_path("../fastlane/*.ipa")).first
    UI.user_error!("No IPA found") unless ipa_path
    UI.message("Uploading: #{ipa_path}")
    upload_to_testflight(
      api_key: @api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
    )
  end
end
